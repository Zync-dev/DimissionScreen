@page
@model DimissionScreen.Pages.UploadModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    Layout = null;
    var tokens = Antiforgery.GetAndStoreTokens(HttpContext);
}
<!DOCTYPE html>
<html lang="da">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="rvt" content="@tokens.RequestToken" />
    <title>Del dine billeder</title>
    <link rel="stylesheet" href="~/css/upload.css" asp-append-version="true" />
</head>
<body>
    <div class="top">
        <div class="chip icon"><svg viewBox="0 0 24 24"><path d="M5 8h2.5l1.5 -2h6l1.5 2H19a1 1 0 0 1 1 1v8a1 1 0 0 1 -1 1H5a1 1 0 0 1 -1 -1V9a1 1 0 0 1 1 -1z"></path><circle cx="12" cy="13" r="3"></circle></svg></div>
        <h1>Del dine billeder</h1>
        <div class="sub">De vises på storskærmen med det samme</div>
    </div>

    <label class="pick" for="file">
        <span class="pick-ico icon"><svg viewBox="0 0 24 24"><path d="M12 15V4"></path><path d="M8 8l4 -4 4 4"></path><path d="M5 14v4a1 1 0 0 0 1 1h12a1 1 0 0 0 1 -1v-4"></path></svg></span>
        <div class="t">Tag et billede eller vælg fra galleriet</div>
        <div class="s">Du kan vælge flere på én gang</div>
    </label>
    <input id="file" type="file" accept="image/*" multiple />

    <div class="name">
        <input id="who" type="text" maxlength="40" placeholder="Dit navn (valgfrit)" />
    </div>

    <div class="grid" id="grid"></div>

    <button class="send" id="send" disabled>Send</button>
    <div class="msg" id="msg"></div>

    <script src="~/js/upload.js" asp-append-version="true"></script>
</body>
</html>
