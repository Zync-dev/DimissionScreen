@page
@model DimissionScreen.Pages.TvModel
@{
    Layout = null;
    var config = new
    {
        title = Model.Title,
        subtitle = Model.Subtitle,
        uploadUrl = Model.UploadUrl,
        jamUrl = Model.JamUrl,
        photosUrl = "/Tv?handler=Photos",
        nowPlayingUrl = "/Tv?handler=NowPlaying"
    };
}
<!DOCTYPE html>
<html lang="da">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Dimission – storskærm</title>
    <link rel="stylesheet" href="~/css/tv.css" asp-append-version="true" />
</head>
<body>
    <div class="screen">
        <div class="topbar">
            <div class="title">@Model.Title<span class="sub">@Model.Subtitle</span></div>
            <div class="live" id="live">
                <span class="dot"></span> <span id="liveText">forbinder…</span>
            </div>
        </div>

        <div class="slide" id="slide">
            <div class="empty" id="empty">
                <span class="icon"><svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="1.5"></rect><circle cx="8.5" cy="10" r="1.5"></circle><path d="M5 17l4.5 -4.5 4 4 2.5 -2.5 3 3"></path></svg></span>
                <div class="t">Scan QR-koden for at sende det første billede</div>
            </div>
            <div class="new" id="new">nyt billede</div>
            <div class="count" id="count" style="display:none">0</div>
        </div>

        <div class="right">
            <div class="card np">
                <div class="label">
                    <span class="icon" id="npIcon"><svg viewBox="0 0 24 24"><polygon points="7 4 20 12 7 20 7 4"></polygon></svg></span>
                    <span id="jamtagText">venter på musik</span>
                </div>
                <div class="now">
                    <div class="art" id="art">
                        <span class="icon"><svg viewBox="0 0 24 24"><circle cx="6" cy="17" r="3"></circle><circle cx="16" cy="15" r="3"></circle><path d="M9 17V5l10 -2v12"></path></svg></span>
                    </div>
                    <div class="meta">
                        <div class="song" id="song">Intet spiller</div>
                        <div class="artist" id="artist">Start jammet på Spotify</div>
                    </div>
                </div>
                <div class="bar"><i id="prog"></i></div>
                <div class="tt"><span id="elapsed">0:00</span><span id="total">0:00</span></div>
            </div>

            <div class="qrs">
                <div class="card qrcard">
                    <div class="qr" id="qrPhoto"></div>
                    <div class="qrlabel">
                        <span class="icon"><svg viewBox="0 0 24 24"><path d="M5 8h2.5l1.5 -2h6l1.5 2H19a1 1 0 0 1 1 1v8a1 1 0 0 1 -1 1H5a1 1 0 0 1 -1 -1V9a1 1 0 0 1 1 -1z"></path><circle cx="12" cy="13" r="3"></circle></svg></span>
                        Upload billede
                    </div>
                </div>
                <div class="card qrcard">
                    <div class="qr" id="qrJam"></div>
                    <div class="qrlabel">
                        <span class="icon"><svg viewBox="0 0 24 24"><circle cx="6" cy="17" r="3"></circle><circle cx="16" cy="15" r="3"></circle><path d="M9 17V5l10 -2v12"></path></svg></span>
                        Join jammet
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>window.TV_CONFIG = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(config));</script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <script src="~/js/tv.js" asp-append-version="true"></script>
</body>
</html>
